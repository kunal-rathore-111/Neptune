{
    "$schema": "https://openapi.vercel.sh/vercel.json",
    "bunVersion": "1.x",
    "installCommand": "cd ../.. && bun install",
    "buildCommand": "cd ../.. && bun run build --filter=Neptune-Server",
    "routes": [
        {
            "src": "/(.*)",
            "dest": "src/index.ts"
        }
    ]
}