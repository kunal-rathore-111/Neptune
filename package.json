{
  "name": "Neptune",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "prettier": "^3.7.4",
    "turbo": "^2.9.6",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "workspaces": [
    "apps/*",
    "apps/*/*",
    "packages/*"
  ],
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.15.0",
    "react-redux": "^9.2.0",
    "s": "./apps/web/client"
  }
}
